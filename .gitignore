# Build output
target/
tools/bin/

# Stale wasm-pack output — canonical output is /pkg (tracked, needed for Pages/deploy)
glimr/pkg/

# Source photos (jpg): ignore stray photos, but COMMIT the curated test fixtures.
# (Real-capture inputs under tests/failed_crops/ stay ignored by this rule.)
*.jpg
!tests/fixtures/*.jpg

# Gallery archives — keep Demo.zip (served sample); ignore the rest
*.zip
!Demo.zip

# The fixtures, the reports (.md/.html) and their generated images under
# tests/reports/output/ are intentionally committed — they ARE the demonstration
# showcase, meant to be browsable in the repo.

# Scratch space for ad-hoc "just experimenting" demo/diagnostic runs — never committed.
tests/local-only/

# Local editor workspace
glimpse-o-matic.code-workspace
